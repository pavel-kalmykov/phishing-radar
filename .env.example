# Database connection.
# Set DATABASE_URL to any DuckDB-compatible string (local path, md: prefix, s3://, etc.).
# When set, the sink, dashboard and dbt use it directly.
DATABASE_URL=

# Redpanda Cloud (Kafka broker) - leave SASL blank for local Redpanda
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
CERTSTREAM_TOPIC=certstream_events
SUSPICIOUS_TOPIC=suspicious_certs
STATS_TOPIC=cert_stats_1min

# CertStream source
CERTSTREAM_URL=ws://localhost:8090/full-stream

# MaxMind (free tier GeoLite2 — optional IP enrichment)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Archive mode: when set to 1, the dashboard reads data/archive.duckdb in read-only
# mode instead of DATABASE_URL, and disables live refresh + date filters.
ARCHIVE_MODE=0

# Sink idempotency and retention.
# Unique indexes on the raw payload column + INSERT OR IGNORE prevent duplicates
# when multiple sink instances consume the same Kafka messages.
# Set SINK_RETENTION to a DuckDB INTERVAL to periodically delete old rows.
# Examples: '400 days', '6 months', '1 year', '12 hours'. Empty = no cleanup.
SINK_RETENTION=
SINK_CLEANUP_INTERVAL_SECONDS=3600

# Sink observability. Each sink worker writes a heartbeat to raw_pipeline_events
# every N seconds. The watchdog checks for stalled workers (no flush in 3x this).
SINK_HEARTBEAT_INTERVAL_SECONDS=60
SINK_WATCHDOG_TIMEOUT_SECONDS=180
